# ============================================================
# LEATrace – Environment Variables
# Copy to .env and fill in your values before starting.
# NEVER commit .env to git.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=leatrace
PG_USER=postgres
PG_PASSWORD=your_postgres_password_here

# ── Blockchain APIs ──────────────────────────────────────────
# Free Etherscan key: https://etherscan.io/register
ETHERSCAN_API_KEY=YourEtherscanApiKeyHere

# Blockstream has no key – it's fully public

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_PASSWORD=leattrace2026
PHYSICS_PASSWORD=antigravity2026
THEORIST_PASSWORD=antigravity2026

# ── Ingestion Scheduler ──────────────────────────────────────
# How often to poll (seconds). 30 is good for development.
INGESTION_INTERVAL_SEC=30

# Wallets to watch automatically (comma-separated address:chain pairs)
# Example: WATCH_WALLETS=0xABC123:ethereum,bc1qXYZ:bitcoin
WATCH_WALLETS=

# ── Server ───────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:5173
